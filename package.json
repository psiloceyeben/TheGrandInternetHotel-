{
  "name": "grand-internet-hotel",
  "version": "1.0.0",
  "description": "The Grand Internet Hotel — 8-bit game client for managing AI-inhabited websites",
  "author": {
    "name": "Prometheus7",
    "url": "https://thegrandinternethotel.com"
  },
  "homepage": "https://thegrandinternethotel.com",
  "license": "MIT",
  "main": "main.js",
  "bin": {
    "grand-internet-hotel": "./launch.js"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --win --mac --linux",
    "dev": "electron . --dev",
    "postinstall": "electron-builder install-app-deps || true"
  },
  "build": {
    "appId": "com.prometheus7.grand-internet-hotel",
    "productName": "Grand Internet Hotel",
    "copyright": "Copyright 2025-2026 Prometheus7",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": "zip",
      "icon": "assets/icon.png",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "assets/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Grand Internet Hotel"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ]
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "node-ssh": "^13.2.0",
    "phaser": "^3.80.1"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
